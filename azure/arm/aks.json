{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "type": "string",
      "defaultValue": "prod",
      "allowedValues": ["dev", "staging", "prod"]
    },
    "clusterName": {
      "type": "string",
      "defaultValue": "gitintel"
    },
    "kubernetesVersion": {
      "type": "string",
      "defaultValue": "1.31"
    },
    "nodeVmSize": {
      "type": "string",
      "defaultValue": "Standard_D2s_v5"
    },
    "nodeCount": {
      "type": "int",
      "defaultValue": 2,
      "minValue": 1,
      "maxValue": 10
    },
    "nodeMinCount": {
      "type": "int",
      "defaultValue": 1
    },
    "nodeMaxCount": {
      "type": "int",
      "defaultValue": 5
    },
    "vnetSubnetId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the AKS subnet"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    }
  },
  "variables": {
    "aksName": "[concat(parameters('clusterName'), '-', parameters('environment'), '-aks')]",
    "nodePoolName": "system",
    "logAnalyticsName": "[concat('gitintel-', parameters('environment'), '-logs')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      },
      "tags": {
        "project": "mcp-git-intel",
        "environment": "[parameters('environment')]"
      }
    },
    {
      "type": "Microsoft.ContainerService/managedClusters",
      "apiVersion": "2024-01-01",
      "name": "[variables('aksName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "sku": {
        "name": "Standard",
        "tier": "Standard"
      },
      "properties": {
        "kubernetesVersion": "[parameters('kubernetesVersion')]",
        "dnsPrefix": "[concat(parameters('clusterName'), '-', parameters('environment'))]",
        "enableRBAC": true,
        "aadProfile": {
          "managed": true,
          "enableAzureRBAC": true
        },
        "agentPoolProfiles": [
          {
            "name": "[variables('nodePoolName')]",
            "count": "[parameters('nodeCount')]",
            "vmSize": "[parameters('nodeVmSize')]",
            "osDiskSizeGB": 128,
            "osDiskType": "Managed",
            "osType": "Linux",
            "osSKU": "AzureLinux",
            "type": "VirtualMachineScaleSets",
            "mode": "System",
            "enableAutoScaling": true,
            "minCount": "[parameters('nodeMinCount')]",
            "maxCount": "[parameters('nodeMaxCount')]",
            "vnetSubnetID": "[parameters('vnetSubnetId')]",
            "availabilityZones": ["1", "2", "3"],
            "nodeTaints": [],
            "nodeLabels": {
              "app": "mcp-git-intel",
              "environment": "[parameters('environment')]"
            },
            "maxPods": 110,
            "upgradeSettings": {
              "maxSurge": "33%"
            }
          }
        ],
        "networkProfile": {
          "networkPlugin": "azure",
          "networkPolicy": "calico",
          "serviceCidr": "172.16.0.0/16",
          "dnsServiceIP": "172.16.0.10",
          "loadBalancerSku": "standard",
          "outboundType": "loadBalancer"
        },
        "addonProfiles": {
          "omsagent": {
            "enabled": true,
            "config": {
              "logAnalyticsWorkspaceResourceID": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
            }
          },
          "azurePolicy": {
            "enabled": true
          }
        },
        "autoUpgradeProfile": {
          "upgradeChannel": "stable"
        },
        "disableLocalAccounts": true,
        "securityProfile": {
          "defender": {
            "securityMonitoring": {
              "enabled": true
            }
          },
          "workloadIdentity": {
            "enabled": true
          }
        },
        "oidcIssuerProfile": {
          "enabled": true
        }
      },
      "tags": {
        "project": "mcp-git-intel",
        "environment": "[parameters('environment')]",
        "managedBy": "arm-template"
      }
    }
  ],
  "outputs": {
    "clusterName": {
      "type": "string",
      "value": "[variables('aksName')]"
    },
    "clusterFqdn": {
      "type": "string",
      "value": "[reference(variables('aksName')).fqdn]"
    },
    "oidcIssuerUrl": {
      "type": "string",
      "value": "[reference(variables('aksName')).oidcIssuerProfile.issuerURL]"
    }
  }
}
